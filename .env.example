# LinkedIn (get li_at cookie from browser DevTools → Application → Cookies → linkedin.com)
LINKEDIN_LI_AT=your_li_at_cookie_here
LINKEDIN_PROFILE_URL=https://www.linkedin.com/in/yourprofile/

# Twitter / X (get auth_token cookie from browser DevTools)
TWITTER_AUTH_TOKEN=your_auth_token_cookie_here
TWITTER_CT0=your_ct0_cookie_here
TWITTER_USERNAME=yourhandle

# YouTube Data API v3 (free, 10K units/day)
YOUTUBE_API_KEY=your_youtube_api_key_here
YOUTUBE_CHANNEL_ID=UCxxxxxxxxxxxxxxxxxx

# OpenAI (for AI-generated comments and cover letters)
OPENAI_API_KEY=sk-your-key-here

# Telegram (for notifications — optional)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id
